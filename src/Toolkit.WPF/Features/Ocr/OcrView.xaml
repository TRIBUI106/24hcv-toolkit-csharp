<UserControl x:Class="Toolkit.WPF.Features.Ocr.OcrView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="1000">

            <!-- Image selection -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Images to Recognize" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ImagePaths, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                             ToolTip="One file path per line"/>
                    <Button Content="Browse Images" Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseImagesCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Config -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="OCR Configuration" Style="{StaticResource FieldLabel}" FontSize="13" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Engine Mode" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding EngineModes}"
                                      SelectedItem="{Binding EngineMode}" Width="140"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,20,0">
                            <TextBlock Text="Page Segmentation" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding PsmModes}"
                                      SelectedItem="{Binding Psm}" Width="140"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="Languages" Style="{StaticResource FieldLabel}"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="Vietnamese" IsChecked="{Binding UseVietnamese}" Margin="0,0,12,0"/>
                                <CheckBox Content="English"    IsChecked="{Binding UseEnglish}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Run OCR" Style="{StaticResource PrimaryButton}"
                                Command="{Binding RunCommand}" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="4" Margin="0,10,0,4"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border Style="{StaticResource Card}">
                <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False"
                          CanUserAddRows="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" BorderThickness="0"
                          Background="Transparent" MaxHeight="380">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File"        Binding="{Binding FileName}"    Width="180" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Confidence"  Binding="{Binding Confidence, StringFormat={}{0:F1}%}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Time (ms)"   Binding="{Binding ProcessingMs}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Recognized Text" Binding="{Binding Text}"   Width="*"   IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
