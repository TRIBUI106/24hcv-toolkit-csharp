<UserControl x:Class="Toolkit.WPF.Features.ImagePreprocessing.ImagePreprocessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="1000">

            <!-- I/O folders -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Input Directory" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding InputDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseInputCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Output Directory" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseOutputCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Options -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Preprocessing Steps" Style="{StaticResource FieldLabel}" FontSize="13" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <CheckBox Content="Deskew"            IsChecked="{Binding Deskew}"     Margin="0,0,20,8"/>
                        <CheckBox Content="Denoise"           IsChecked="{Binding Denoise}"    Margin="0,0,20,8"/>
                        <CheckBox Content="CLAHE Contrast"    IsChecked="{Binding ApplyClahe}" Margin="0,0,20,8"/>
                        <CheckBox Content="Otsu Binarization" IsChecked="{Binding ApplyOtsu}"  Margin="0,0,20,8"/>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Target DPI:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding TargetDpi, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Process Images" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ProcessCommand}" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="4" Margin="0,10,0,4"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border Style="{StaticResource Card}">
                <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False"
                          CanUserAddRows="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" BorderThickness="0"
                          Background="Transparent" MaxHeight="380">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File"          Binding="{Binding FileName}"     Width="*"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="Steps Applied" Binding="{Binding Steps}"        Width="300" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Time (ms)"     Binding="{Binding ProcessingMs}" Width="80"  IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
