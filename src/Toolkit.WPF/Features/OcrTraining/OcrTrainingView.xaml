<UserControl x:Class="Toolkit.WPF.Features.OcrTraining.OcrTrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="1000">

            <!-- Data generation -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="1. Generate Synthetic Training Data" FontSize="14" FontWeight="SemiBold"
                               Foreground="#1E293B" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Output Directory" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding GenerateOutputDir, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseGenerateOutputCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Sample Count" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SampleCount, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Fonts (comma-separated)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding FontList, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="Generate Data" Style="{StaticResource PrimaryButton}"
                            Command="{Binding GenerateDataCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Training -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="2. Train / Fine-tune Model" FontSize="14" FontWeight="SemiBold"
                               Foreground="#1E293B" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Dataset Directory" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding DatasetDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseDatasetCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Output Model Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Start Training" Style="{StaticResource PrimaryButton}"
                                Command="{Binding TrainCommand}" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"/>
                    </StackPanel>

                    <!-- Progress + log -->
                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="4" Margin="0,10,0,4"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#64748B"/>
                    <TextBox Text="{Binding TrainingLog}" IsReadOnly="True" Height="100"
                             Background="#F1F5F9" FontFamily="Consolas" FontSize="11"
                             VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                             Margin="0,8,0,0"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Border>

            <!-- Evaluation -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="3. Evaluate Model" FontSize="14" FontWeight="SemiBold"
                               Foreground="#1E293B" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Model (.traineddata)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseModelCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Test Data Directory" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding TestDataDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseTestDataCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                    <Button Content="Evaluate" Style="{StaticResource PrimaryButton}"
                            Command="{Binding EvaluateCommand}" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <TextBox Text="{Binding EvaluationResult}" IsReadOnly="True" Height="90"
                             Background="#F1F5F9" FontFamily="Consolas" FontSize="13"
                             BorderThickness="0" TextWrapping="NoWrap"
                             Visibility="{Binding EvaluationResult, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
