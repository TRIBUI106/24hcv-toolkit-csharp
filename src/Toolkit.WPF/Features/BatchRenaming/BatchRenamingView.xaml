<UserControl x:Class="Toolkit.WPF.Features.BatchRenaming.BatchRenamingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="1000">

            <!-- Folder + spec -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Root Folders" Style="{StaticResource FieldLabel}"/>

                    <!-- TextBox + Browse -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="RootFolderTextBox"
                                 Margin="0,0,8,0"
                                 AllowDrop="True"
                                 Drop="RootFolderTextBox_Drop"
                                 DragOver="RootFolderTextBox_DragOver"
                                 ToolTip="Nhập đường dẫn rồi nhấn Enter, hoặc kéo thả folder vào đây"
                                 KeyDown="RootFolderTextBox_KeyDown"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseFolderCommand}"/>
                    </Grid>

                    <!-- Drop zone -->
                    <Border x:Name="DropZone"
                            BorderBrush="#CBD5E1" BorderThickness="2" CornerRadius="8"
                            Background="#F8FAFC" Height="72" Margin="0,0,0,12"
                            AllowDrop="True"
                            Drop="DropZone_Drop"
                            DragOver="DropZone_DragOver"
                            DragLeave="DropZone_DragLeave">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="DropZoneText"
                                       Text="Kéo một hoặc nhiều folder vào đây"
                                       FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Folder list -->
                    <ItemsControl ItemsSource="{Binding RootFolders}" Margin="0,0,0,12"
                                  Visibility="{Binding RootFolders.Count, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6"
                                        Background="#F1F5F9" Margin="0,0,0,4" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12"
                                                   Foreground="#1E293B" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1" Content="✕" Margin="8,0,0,0"
                                                FontSize="11" Padding="6,2"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DataContext.RemoveFolderCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Thông số đặt tên" Style="{StaticResource FieldLabel}" FontSize="13" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Mã định danh *" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MaDinhDanh, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Mã phông *" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MaPhong, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Mã mục lục *" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MaMucLuc, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Preview" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PreviewCommand}" Margin="0,0,8,0"/>
                        <Button Content="Rename" Style="{StaticResource PrimaryButton}"
                                Command="{Binding RenameCommand}"/>
                    </StackPanel>

                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="4"
                                 Margin="0,10,0,4"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <!-- File preview table -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Xem trước đổi tên file" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding PreviewItems}" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent" MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Root folder"        Binding="{Binding RootFolder}" Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Hồ sơ (subfolder)"  Binding="{Binding Subfolder}"  Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tên cũ"             Binding="{Binding OldName}"    Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tên mới"            Binding="{Binding NewName}"    Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
